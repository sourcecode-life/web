---
import { getLangFromUrl, useTranslations, languages, getLocalizedPath } from '../i18n/utils';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const url = Astro.url;
const lang = getLangFromUrl(url);
const t = useTranslations(lang);

const {
  title = t('site.title'),
  description = t('site.description')
} = Astro.props;

const htmlLang = lang === 'zh-hans' ? 'zh-CN' : lang === 'zh-hant' ? 'zh-TW' : lang;

const hreflangs = Object.keys(languages).map((l) => ({
  lang: l === 'zh-hans' ? 'zh-CN' : l === 'zh-hant' ? 'zh-TW' : l,
  href: `https://sourcecode.life${getLocalizedPath('/', l as keyof typeof languages)}`,
}));
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url.href} />
    <meta property="og:site_name" content="SourceCode.Life" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {hreflangs.map(({ lang, href }) => (
      <link rel="alternate" hreflang={lang} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://sourcecode.life/" />

    <link rel="canonical" href={url.href} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gradient-to-b from-gray-900 via-gray-950 to-black text-white">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
