---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="fixed top-0 left-0 right-0 z-50 bg-gray-900/90 backdrop-blur-md border-b border-gray-800">
  <nav class="container mx-auto px-4 py-4 flex items-center justify-between max-w-6xl">
    <a
      href={getLocalizedPath('/', lang)}
      class="text-sm sm:text-xl font-bold text-green-400 font-mono hover:text-green-300 transition-colors"
    >
      ~/sourcecode.life
    </a>
    <div class="flex items-center gap-2 sm:gap-6">
      <a
        href="#what"
        data-section="what"
        class="nav-link text-gray-300 hover:text-green-400 transition-colors text-sm sm:text-base"
      >
        {t('nav.what')}
      </a>
      <a
        href="#why"
        data-section="why"
        class="nav-link text-gray-300 hover:text-green-400 transition-colors text-sm sm:text-base"
      >
        {t('nav.why')}
      </a>
      <a
        href="#how"
        data-section="how"
        class="nav-link text-gray-300 hover:text-green-400 transition-colors text-sm sm:text-base"
      >
        {t('nav.how')}
      </a>
      <a
        href="#goal"
        data-section="goal"
        class="nav-link text-gray-300 hover:text-green-400 transition-colors text-sm sm:text-base"
      >
        {t('nav.goal')}
      </a>
      <LanguageSwitcher />
    </div>
  </nav>
</header>

<style>
  .nav-link.active {
    color: #4ade80;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('div[id], section[id]');
    const navLinks = document.querySelectorAll('.nav-link');

    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -60% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navLinks.forEach((link) => {
            link.classList.remove('active');
            if (link.getAttribute('data-section') === id) {
              link.classList.add('active');
            }
          });
        }
      });
    }, observerOptions);

    sections.forEach((section) => {
      if (['what', 'why', 'how', 'goal'].includes(section.id)) {
        observer.observe(section);
      }
    });
  });
</script>
