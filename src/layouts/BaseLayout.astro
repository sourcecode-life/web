---
import { getLangFromUrl, useTranslations, languages, getLocalizedPath } from '../i18n/utils';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const url = Astro.url;
const lang = getLangFromUrl(url);
const t = useTranslations(lang);

const {
  title = t('site.title'),
  description = t('site.description')
} = Astro.props;

const htmlLang = lang === 'zh-hans' ? 'zh-CN' : lang === 'zh-hant' ? 'zh-TW' : lang;

const hreflangs = Object.keys(languages).map((l) => ({
  lang: l === 'zh-hans' ? 'zh-CN' : l === 'zh-hant' ? 'zh-TW' : l,
  href: `https://sourcecode.life${getLocalizedPath('/', l as keyof typeof languages)}`,
}));
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url.href} />
    <meta property="og:site_name" content="SourceCode.Life" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {hreflangs.map(({ lang, href }) => (
      <link rel="alternate" hreflang={lang} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://sourcecode.life/" />

    <link rel="canonical" href={url.href} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-black text-white">
    <canvas id="matrix-bg" class="fixed inset-0 w-full h-full pointer-events-none z-0"></canvas>
    <div class="relative z-10">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      const canvas = document.getElementById('matrix-bg') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // Quantum code symbols: qubits, superposition, gates, binary
      const chars = '|0⟩|1⟩|+⟩|−⟩⟨ψ|Φ⟩01αβ∧⊗⊕∑∫∂ℏΔπ∞≡≈';
      const fontSize = 14;
      const speed = 0.3;
      let columns = Math.floor(canvas.width / fontSize);
      let drops: number[] = Array(columns).fill(0).map(() => Math.random() * -100);

      window.addEventListener('resize', () => {
        columns = Math.floor(canvas.width / fontSize);
        drops = Array(columns).fill(0).map(() => Math.random() * -100);
      });

      function draw() {
        ctx.fillStyle = 'rgba(0, 0, 0, 0.06)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.font = `${fontSize}px monospace`;

        for (let i = 0; i < drops.length; i++) {
          // Only render ~40% of columns for a sparser look
          if (i % 3 !== 0) {
            drops[i] += speed;
            if (drops[i] * fontSize > canvas.height && Math.random() > 0.98) {
              drops[i] = 0;
            }
            continue;
          }

          const char = chars[Math.floor(Math.random() * chars.length)];
          const x = i * fontSize;
          const y = drops[i] * fontSize;

          ctx.fillStyle = `rgba(74, 222, 128, ${0.08 + Math.random() * 0.07})`;
          ctx.fillText(char, x, y);

          if (y > canvas.height && Math.random() > 0.98) {
            drops[i] = 0;
          }
          drops[i] += speed;
        }

        requestAnimationFrame(draw);
      }
      draw();
    </script>
  </body>
</html>
