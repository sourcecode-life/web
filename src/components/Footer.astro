---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="border-t border-gray-800 py-8 px-4">
  <div class="container mx-auto max-w-6xl flex flex-col md:flex-row md:justify-between md:items-start gap-6">
    <!-- Poem (shown first on mobile, right side on desktop) -->
    <div class="order-first md:order-last text-left md:text-right text-purple-400 text-base md:text-base leading-relaxed font-bold">
      {lang === 'en' && (
        <>
          <p>All is energy.</p>
          <p>Everything is code.</p>
          <p>Life runs as an algorithm.</p>
          <p>Source defines output.</p>
        </>
      )}
      {lang === 'zh-hans' && (
        <>
          <p>一切皆能量</p>
          <p>万物皆编码</p>
          <p>命运如算法</p>
          <p>修行改源码</p>
        </>
      )}
      {lang === 'zh-hant' && (
        <>
          <p>一切皆能量</p>
          <p>萬物皆編碼</p>
          <p>命運如算法</p>
          <p>修行改源碼</p>
        </>
      )}
    </div>
    <!-- Contact & copyright (shown second on mobile, left side on desktop) -->
    <div class="order-last md:order-first text-left">
      <p class="text-sm mb-2 flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-500 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        {lang === 'en' && <><span class="text-gray-500">Like this idea? </span><a href="https://github.com/sourcecode-life/sourcecode.life" target="_blank" class="text-green-400 hover:text-white transition-colors">Star us on GitHub</a></>}
        {lang === 'zh-hans' && <><span class="text-gray-500">喜欢这个理念？</span><a href="https://github.com/sourcecode-life/sourcecode.life" target="_blank" class="text-green-400 hover:text-white transition-colors">在 GitHub 上给我们 Star</a></>}
        {lang === 'zh-hant' && <><span class="text-gray-500">喜歡這個理念？</span><a href="https://github.com/sourcecode-life/sourcecode.life" target="_blank" class="text-green-400 hover:text-white transition-colors">在 GitHub 上給我們 Star</a></>}
      </p>
      <p class="text-sm mb-2 flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
        <span class="text-gray-500">{lang === 'en' ? 'Contact: ' : '联系：'}</span><a href="mailto:rewrite@sourcecode.life" class="text-green-400 font-mono hover:text-white transition-colors">rewrite@sourcecode.life</a>
      </p>
      <p class="text-gray-500 text-sm flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-500 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        {lang === 'en' && <>Rewrite your <span class="text-green-400">source code</span>. Upgrade your <span class="text-green-400">life</span>.</>}
        {lang === 'zh-hans' && <>重写你的<span class="text-green-400">源代码</span>，升级你的<span class="text-green-400">生命</span>。</>}
        {lang === 'zh-hant' && <>重寫你的<span class="text-green-400">源代碼</span>，升級你的<span class="text-green-400">生命</span>。</>}
      </p>
      <p class="text-gray-600 text-xs mt-2">
        {t('footer.copyright')}
      </p>
    </div>
  </div>
</footer>
